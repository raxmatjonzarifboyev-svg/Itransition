   "source": [
    "select cast(year as int) as year ,count(*) as book_count,\n",
    "round(avg(case when price like '€%' then round(cast(replace(price,'€','') as double)*1.2,2)\n",
    "else cast(replace(price,'$','') as double) end ),2) as avg_price\n",
    "from `itransition`.`default`.`first_tast`\n",
    "group by year\n",
    "order by year"
   ]
  }
